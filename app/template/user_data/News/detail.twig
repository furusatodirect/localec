{% extends 'default_frame.twig' %}

{% set body_class = 'news_page' %}

{% block main %}
<main id="about">
<div class="container">


<div class="small container">
<h3>お知らせ</h3>


  <div class="news-{{ news.id }}">
    <h6>{{ news.publish_date|date("Y/m/d") }}</h6>
    <h4 class="uline">{{ news.title }}</h4>

    {% if news.npThumbnailUrl is defined and news.npThumbnailUrl %}
     <div class="image"> <img src="{{ asset(news.npThumbnailUrl, 'save_image') }}" alt="{{ news.title }}"></div>
    {% endif %}
    <p>{{ news.description|raw|nl2br }}</p>

  </div>

</div>

</div>

</main>
{% endblock %}
