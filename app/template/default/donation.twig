{% extends 'default_frame.twig' %}


{# donation 専用スタイルは customize.css へ集約済み #}


{% block main %}

  <main id="about">

   

    <div class="container">
        
        

      <div id="p-donation">
        <div class="card col-md-8 mx-auto">

          <div class="card-header">
            <p class="title">stg紋別応援寄付</p>
          </div>

          <div class="row col-md-10 mx-auto">
            <div class="card-body m-3">
              <p class="lead">紋別応援寄付では返礼品を受け取ることはできませんが、<br>寄付金をもっと課題解決に役立てることができます。</p>

            </div>
          </div>

          <div class="row m-0">
                    <p class="sub-header">リストから好きな金額をお選びいただけます。</p>
            <div class="col-6 col-md-4 m-3 mx-auto">
              <form>
                <div class="form-group">

                  <div class="ec-select">
                    <select id="donation_price" name="donation[price]" class="form-control">
                      <option value="">-</option>
                      <option value="2000">2,000</option>
                      <option value="3000">3,000</option>
                      <option value="4000">4,000</option>
                      <option value="5000">5,000</option>
                      <option value="6000">6,000</option>
                      <option value="7000">7,000</option>
                      <option value="8000">8,000</option>
                      <option value="9000">9,000</option>
                      <option value="10000">10,000</option>
                      <option value="20000">20,000</option>
                      <option value="30000">30,000</option>
                      <option value="40000">40,000</option>
                      <option value="50000">50,000</option>
                      <option value="60000">60,000</option>
                      <option value="70000">70,000</option>
                      <option value="80000">80,000</option>
                      <option value="90000">90,000</option>
                      <option value="100000">100,000</option>
                    </select>&nbsp;円
                  </div>
                </div>
              </form>
            </div>
          </div>

          <div class="row m-0">
            <div class="attention col-10 col-md-8 mx-auto">
              <p class="title"><i class="fa fa-exclamation-triangle fa-fw"></i>注意事項</p>
              <p class="lead">※2,000円以上の寄付金額からお申し込みいただけます。<br>
                ※こちらの寄付では返礼品の申し込みはできません。</p>
            </div>
          </div>

          <div class="row col-8 mb-5 mx-auto">
            {% if is_granted('ROLE_USER') %} 
            <a class="ec-blockBtn--action" href="{{ url('cart') }}">お申し込みに進む</a>
          {% else %}
          <a class="ec-blockBtn--action" href="{{ url('mypage_login') }}">お申し込みに進む</a>
          {% endif %}
          <a class="ec-blockBtn--cancel" href="{{ path('homepage') }}">前の画面に戻る</a>
          </div>

        </div>
      </div>

    </div>

  </main>

{% endblock %}